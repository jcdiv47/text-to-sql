# Assistant Cloud API URL -- sign up on cloud.assistant-ui.com
NEXT_PUBLIC_ASSISTANT_BASE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Mastra SQL agent model provider
OPENROUTER_API_KEY=

# PostgreSQL database queried by the SQL agent
DATABASE_URL=
DATABASE_SCHEMA=aiqa

# Mastra project
MASTRA_PLATFORM_ACCESS_TOKEN=
MASTRA_PROJECT_ID=

# Mastra persistent storage. For Turso, use your libsql:// database URL and auth token.
MASTRA_STORAGE_URL=
MASTRA_STORAGE_AUTH_TOKEN=
