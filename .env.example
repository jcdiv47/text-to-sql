# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxx
CLERK_SECRET_KEY=sk_test_xxxx

# Convex (server-side chat persistence). `npx convex dev` writes these two.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=
# Set in the Convex deployment env (dashboard or `npx convex env set`), NOT here:
#   CLERK_JWT_ISSUER_DOMAIN=https://<your-app>.clerk.accounts.dev

# Mastra SQL agent model provider
OPENROUTER_API_KEY=

# PostgreSQL database queried by the SQL agent
DATABASE_URL=
DATABASE_SCHEMA=aiqa

# Langfuse tracing for the Mastra SQL agent
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
